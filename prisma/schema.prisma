generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id         Int      @id @default(autoincrement())
  nombre     String
  email      String
  telefono   String?
  tipoDolor  String
  mensaje    String
  creadoEn   DateTime @default(now())

  @@map("contact_messages")
}
